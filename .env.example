ADO_PAT=(PAT from Azure DevOps)
ADO_URL=(https://dev.azure.com/ORG)
APPLICATIONINSIGHTS_CONNECTION_STRING=(Connection string from Azure Application Insights, or blank if not using)
ASANA_TOKEN=(PAT from Asana)
ASANA_WORKSPACE_NAME=(Name of the Asana Workspace)
OTEL_SERVICE_NAME=sync
# Trace sampling percentage to reduce Application Insights cost (0.05 = 5%, 1.0 = 100%)
OTEL_TRACES_SAMPLER_ARG=0.05
CLOSED_STATES=Closed,Removed,Done
THREAD_COUNT=8
SLEEP_TIME=300
# RUN_ONCE=false
# DRY_RUN=false
SYNCED_TAG_NAME=synced

# Group/container reviewer fallback strategy (ignore | default_user | unassigned_task | expand_group_members, default: ignore)
# ignore: skip group reviewers (current behaviour)
# default_user: assign group reviewer tasks to GROUP_REVIEWER_DEFAULT_USER
# unassigned_task: create an unassigned task with the group name in the title
# expand_group_members: resolve group to individual members via ADO Graph API (requires vso.graph PAT scope)
GROUP_REVIEWER_STRATEGY=ignore
# Asana user email, GID, or display name to use when GROUP_REVIEWER_STRATEGY=default_user
GROUP_REVIEWER_DEFAULT_USER=
# TTL in hours for the group member cache (used with expand_group_members strategy, default: 6.0)
# GROUP_CACHE_TTL_HOURS=6.0

# Telemetry Logging Configuration
# Console log level (default: INFO) - controls what is shown in the terminal
LOGLEVEL=INFO
# Application Insights log level (default: WARNING) - controls minimum level sent to telemetry
APPINSIGHTS_LOGLEVEL=WARNING
# Sampling rates for telemetry by log level (0.0 = 0%, 1.0 = 100%)
# WARNING, ERROR, CRITICAL default to 100% to preserve incident visibility
# INFO, DEBUG default to 5% to reduce Application Insights ingestion volume
APPINSIGHTS_SAMPLE_DEBUG=0.05
APPINSIGHTS_SAMPLE_INFO=0.05
APPINSIGHTS_SAMPLE_WARNING=1.0
APPINSIGHTS_SAMPLE_ERROR=1.0
APPINSIGHTS_SAMPLE_CRITICAL=1.0
