{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "separateMajorMinor": true,
  "packageRules": [
    {
      "description": "Create one PR per skipped major version",
      "matchUpdateTypes": [
        "major"
      ],
      "separateMultipleMajor": true
    }
  ]
}
